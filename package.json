{
  "name": "demi-syntax",
  "displayName": "DemiSyntax",
  "description": "Syntax highlighting for Demi DASM assembly and the Demi higher-level language",
  "version": "0.1.0",
  "publisher": "bobrossrtx",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "demi",
    "dasm",
    "assembly",
    "disa",
    "isa"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dasm",
        "aliases": ["DASM", "dasm", "Demi Assembly"],
        "extensions": [".asm", ".dasm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dasm",
        "scopeName": "source.dasm",
        "path": "./syntaxes/dasm.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bobrossrtx/demi-syntax"
  }
}
